# Cheia de acces pentru aplicație (server-only, nu expune în client).
# Setează aceeași valoare în Vercel: Project Settings → Environment Variables
APP_ACCESS_KEY=your-secret-key-here

# Fișier JSON pentru datele de tracking (local dev)
DATA_FILE_PATH=data/track.json

# Pe Vercel: creează un Blob store (Project → Storage → Blob → Connect).
# Tokenul BLOB_READ_WRITE_TOKEN se injectează automat după connect.
